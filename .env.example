# Kalshi (optional — public market data works without auth)
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY_PATH=

# Polymarket (defaults work for read-only research)
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com

# LLM — API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# LLM — Vertex / Gemini service account JSON
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

# LiteLLM proxy (optional)
LITELLM_MODE=local_library
LITELLM_API_KEY=
LITELLM_PROXY_BASE_URL=http://localhost:4000
LITELLM_DATABASE_URL=postgresql://fin_agents:fin_agents@localhost:5432/litellm

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Postgres (app + docker)
DATABASE_URL=postgresql://fin_agents:fin_agents@localhost:5432/fin_agents
POSTGRES_USER=fin_agents
POSTGRES_PASSWORD=fin_agents
